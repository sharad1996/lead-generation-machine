# Prisma requires MongoDB as a replica set. "Connection refused" = nothing listening — start Mongo or fix URL.
#
# Local: `npm run db:mongo:native-help` then brew services start … + native-init. Docker: Desktop running + db:mongo:up + port 27018.
# Cloud: MongoDB Atlas URI (no extra replicaSet= on mongodb+srv).
DATABASE_URL="mongodb://127.0.0.1:27017/leadmachine?replicaSet=rs0&directConnection=true"
PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
