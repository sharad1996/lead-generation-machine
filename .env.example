# --- Pick ONE database (Prisma needs a replica set) ---
#
# A) No Docker: Homebrew Mongo on 27017 with replSet rs0 — see: npm run db:mongo:native-help
DATABASE_URL="mongodb://127.0.0.1:27017/leadmachine?replicaSet=rs0&directConnection=true"
#
# B) Docker Desktop / OrbStack RUNNING: npm run db:mongo:up — then use port 27018:
# DATABASE_URL="mongodb://127.0.0.1:27018/leadmachine?replicaSet=rs0&directConnection=true"
#
# C) MongoDB Atlas (no local Mongo): paste Connect string only; do NOT add replicaSet=rs0 to mongodb+srv:
# DATABASE_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/leadmachine?retryWrites=true&w=majority"

# Redis + worker for BullMQ async scrapes
REDIS_URL="redis://localhost:6379"

# Scraper
SCRAPER_CONCURRENCY="2"
SCRAPER_PROXY_SERVER=""
BROWSER_WS_ENDPOINT=""
SCRAPER_USER_AGENT=""
# Set to 1 to store every scraped lead (same as API bypassWebsiteFilter).
SCRAPER_BYPASS_WEBSITE_FILTER="0"
# 1 = headless shell (default; needs: npm run browsers:install). Google Maps often blocks headless — try 0 for a real window.
PUPPETEER_HEADLESS="1"
# Optional: system Chrome, e.g. macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=""

# Cron (Next.js server process)
ENABLE_CRON="0"
SCRAPE_CRON_EXPRESSION="0 3 * * *"
SCRAPER_CRON_KEYWORDS='["medical distributor"]'
SCRAPER_CRON_LOCATIONS='["Texas","California"]'
SCRAPER_CRON_ENRICH="0"
SCRAPER_MAX_PLACES="15"

# Enrichment
HUNTER_API_KEY=""
APOLLO_API_KEY=""

# Email (NodeMailer)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="0"

# WhatsApp (optional Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Google Sheets append (optional)
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SHEET_ID=""
GOOGLE_SHEET_RANGE="Leads!A1"

# Logging
LOG_LEVEL="info"
